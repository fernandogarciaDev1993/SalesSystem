@inherits LayoutComponentBase
@inject ApiService Api
@inject NavigationManager Nav

@if (IsPublicPage)
{
    @Body
}
else if (_authChecked && !Api.IsAuthenticated)
{
    <div class="d-flex justify-content-center align-items-center" style="min-height: 100vh; background: linear-gradient(135deg, #FDF8F5 0%, #F5EDE8 100%);">
        <div class="text-center">
            <img src="images/logo.png" alt="Afeto no Pote" style="width: 120px;" />
            <p class="mt-2" style="color: #8C7568;">Voce precisa estar logado para acessar o sistema.</p>
            <a href="/login" class="btn btn-primary px-4">
                <i class="bi bi-box-arrow-in-right me-1"></i>Ir para Login
            </a>
        </div>
    </div>
}
else if (_authChecked && Api.IsAuthenticated)
{
    <div class="d-flex" style="min-height: 100vh;">
        <nav class="d-flex flex-column sidebar-nav"
             style="width: @(SidebarCollapsed ? "0" : "260px"); height: 100vh; background: linear-gradient(180deg, #F2EAE4 0%, #E8DDD5 100%); border-right: 1px solid #D4C8BE; transition: width 0.3s; overflow: hidden; position: fixed; z-index: 1000;">
            <div class="p-3 text-center" style="flex-shrink: 0; border-bottom: 1px solid #D4C8BE;">
                <img src="images/logo.png" alt="Afeto no Pote" style="width: 80px; height: 80px; object-fit: contain; margin-bottom: 4px;" />
                <div style="color: #9C8B80; font-size: 0.7rem; letter-spacing: 0.08em;">feito como em casa</div>
            </div>
            <div class="flex-grow-1 py-2" style="overflow-y: auto; overflow-x: hidden;">
                <NavMenu />
            </div>
        </nav>

        <div class="flex-grow-1" style="margin-left: @(SidebarCollapsed ? "0" : "250px"); transition: margin-left 0.3s;">
            <header class="bg-white border-bottom shadow-sm px-3 py-2 d-flex align-items-center justify-content-between" style="height: 56px; position: sticky; top: 0; z-index: 999;">
                <button class="btn btn-sm btn-outline-secondary border-0" @onclick="ToggleSidebar">
                    <i class="bi bi-list fs-5"></i>
                </button>
                <div class="d-flex align-items-center gap-3">
                    <span class="text-muted small">
                        <i class="bi bi-person-circle me-1"></i>@Api.UserName
                        <span class="badge bg-primary ms-1">@Api.UserRole</span>
                    </span>
                    <a href="/logout.html" class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-box-arrow-right me-1"></i>Sair
                    </a>
                </div>
            </header>
            <main class="p-4">@Body</main>
        </div>
    </div>
}
else
{
    <div class="d-flex justify-content-center align-items-center" style="min-height: 100vh;">
        <div class="spinner-border text-primary" role="status"></div>
    </div>
}

@code {
    private bool SidebarCollapsed;
    private bool _authChecked;

    private bool IsPublicPage
    {
        get
        {
            var uri = Nav.Uri.ToLowerInvariant();
            return uri.Contains("/login") || uri.Contains("/logout");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !IsPublicPage)
        {
            await Api.EnsureInitializedAsync();
            _authChecked = true;
            StateHasChanged();
        }
    }

    protected override void OnParametersSet()
    {
        // When navigating within the app after login, token is already in memory
        if (!_authChecked && Api.IsAuthenticated)
        {
            _authChecked = true;
        }
    }

    private void ToggleSidebar() => SidebarCollapsed = !SidebarCollapsed;
}
