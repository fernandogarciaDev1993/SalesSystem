@inject ApiService Api
@inject ILabelService Labels

<nav class="nav flex-column px-2">
    <div class="nav-item mb-1">
        <NavLink class="nav-link rounded px-3 py-2" style="color: var(--sidebar-text, #5C4033);" href="" Match="NavLinkMatch.All">
            <i class="bi bi-speedometer2 me-2"></i> Dashboard
        </NavLink>
    </div>

    <div class="px-3 mt-2 mb-1"><small class="text-uppercase fw-bold" style="color: var(--sidebar-text, #9C8B80); opacity: 0.6; font-size: 0.7rem; letter-spacing: 0.08em;">@Labels.Plural(LabelKeys.Purchase)</small></div>
    <div class="nav-item mb-1">
        <NavLink class="nav-link rounded px-3 py-2" style="color: var(--sidebar-text, #5C4033);" href="insumos">
            <i class="bi bi-basket me-2"></i> @Labels.Plural(LabelKeys.Insumo)
        </NavLink>
    </div>

    <div class="px-3 mt-2 mb-1"><small class="text-uppercase fw-bold" style="color: var(--sidebar-text, #9C8B80); opacity: 0.6; font-size: 0.7rem; letter-spacing: 0.08em;">@Labels.Singular(LabelKeys.Production)</small></div>
    <div class="nav-item mb-1">
        <NavLink class="nav-link rounded px-3 py-2" style="color: var(--sidebar-text, #5C4033);" href="products">
            <i class="bi bi-box-seam me-2"></i> @Labels.Plural(LabelKeys.Product)
        </NavLink>
    </div>
    <div class="nav-item mb-1">
        <NavLink class="nav-link rounded px-3 py-2" style="color: var(--sidebar-text, #5C4033);" href="recipes">
            <i class="bi bi-journal-text me-2"></i> @Labels.Plural(LabelKeys.Recipe)
        </NavLink>
    </div>
    <div class="nav-item mb-1">
        <NavLink class="nav-link rounded px-3 py-2" style="color: var(--sidebar-text, #5C4033);" href="production">
            <i class="bi bi-gear me-2"></i> @Labels.Singular(LabelKeys.Production)
        </NavLink>
    </div>

    <div class="px-3 mt-2 mb-1"><small class="text-uppercase fw-bold" style="color: var(--sidebar-text, #9C8B80); opacity: 0.6; font-size: 0.7rem; letter-spacing: 0.08em;">Vendas</small></div>
    <div class="nav-item mb-1">
        <NavLink class="nav-link rounded px-3 py-2" style="color: var(--sidebar-text, #5C4033);" href="customers">
            <i class="bi bi-people me-2"></i> @Labels.Plural(LabelKeys.Customer)
        </NavLink>
    </div>
    <div class="nav-item mb-1">
        <NavLink class="nav-link rounded px-3 py-2" style="color: var(--sidebar-text, #5C4033);" href="orders">
            <i class="bi bi-cart3 me-2"></i> @Labels.Plural(LabelKeys.Order)
        </NavLink>
    </div>

    <div class="px-3 mt-2 mb-1"><small class="text-uppercase fw-bold" style="color: var(--sidebar-text, #9C8B80); opacity: 0.6; font-size: 0.7rem; letter-spacing: 0.08em;">Controle</small></div>
    <div class="nav-item mb-1">
        <NavLink class="nav-link rounded px-3 py-2" style="color: var(--sidebar-text, #5C4033);" href="stock">
            <i class="bi bi-boxes me-2"></i> @Labels.Singular(LabelKeys.Stock)
        </NavLink>
    </div>
    <div class="nav-item mb-1">
        <NavLink class="nav-link rounded px-3 py-2" style="color: var(--sidebar-text, #5C4033);" href="stock/low">
            <i class="bi bi-exclamation-triangle me-2"></i> @Labels.Singular(LabelKeys.Stock) Baixo
        </NavLink>
    </div>
    <div class="nav-item mb-1">
        <NavLink class="nav-link rounded px-3 py-2" style="color: var(--sidebar-text, #5C4033);" href="financial">
            <i class="bi bi-cash-stack me-2"></i> @Labels.Singular(LabelKeys.Financial)
        </NavLink>
    </div>
    <div class="nav-item mb-1">
        <NavLink class="nav-link rounded px-3 py-2" style="color: var(--sidebar-text, #5C4033);" href="financial/monthly">
            <i class="bi bi-calendar-month me-2"></i> Relatório Mensal
        </NavLink>
    </div>

    @if (Api.IsGlobalAdmin)
    {
        <div class="px-3 mt-2 mb-1"><small style="color: var(--sidebar-text, #9C8B80); opacity: 0.6; font-size: 0.7rem; letter-spacing: 0.08em;" class="text-uppercase fw-bold">Administracao</small></div>
        <div class="nav-item mb-1">
            <NavLink class="nav-link rounded px-3 py-2" style="color: var(--sidebar-text, #5C4033);" href="admin/tenants">
                <i class="bi bi-building me-2"></i> Tenants
            </NavLink>
        </div>
    }
</nav>
