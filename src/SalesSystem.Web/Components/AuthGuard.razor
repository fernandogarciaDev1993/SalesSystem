@inject ApiService Api
@inject NavigationManager Nav

@if (Api.IsAuthenticated)
{
    @ChildContent
}
else if (_checked)
{
    <div class="d-flex justify-content-center align-items-center" style="min-height: 60vh;">
        <div class="text-center">
            <i class="bi bi-lock fs-1 text-muted"></i>
            <p class="text-muted mt-3">Voce precisa estar logado para acessar esta pagina.</p>
            <a href="/login" class="btn btn-primary">
                <i class="bi bi-box-arrow-in-right me-1"></i>Ir para Login
            </a>
        </div>
    </div>
}

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    private bool _checked;

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender && !Api.IsAuthenticated)
        {
            _checked = true;
            Nav.NavigateTo("/login", false);
        }
    }
}
