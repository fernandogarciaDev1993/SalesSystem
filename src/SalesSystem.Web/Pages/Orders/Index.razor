@page "/orders"
@rendermode InteractiveServer
@inject ApiService Api
@inject NavigationManager Nav

<PageTitle>Pedidos - SalesSystem</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="mb-0">Pedidos</h3>
    <a href="/orders/new" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Novo Pedido
    </a>
</div>

<AlertModal Visible="errorMessage is not null" Message="@(errorMessage ?? "")" Title="Erro" Type="error" OnClose="() => errorMessage = null" />

@if (loading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary"></div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Numero</th>
                            <th>Cliente</th>
                            <th>Status</th>
                            <th class="text-end">Total</th>
                            <th>Data</th>
                            <th class="text-center">Acoes</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (orders?.Any() == true)
                        {
                            @foreach (var o in orders)
                            {
                                <tr>
                                    <td><strong>@o.OrderNumber</strong></td>
                                    <td>@o.CustomerName</td>
                                    <td><span class="badge @GetStatusBadge(o.Status)">@o.Status</span></td>
                                    <td class="text-end">@o.Total.ToString("C", ptBR)</td>
                                    <td>@o.CreatedAt.ToString("dd/MM/yyyy")</td>
                                    <td class="text-center">
                                        @if (o.Status == "Rascunho")
                                        {
                                            <button class="btn btn-sm btn-outline-success me-1" @onclick="() => ConfirmOrder(o.Id)" title="Confirmar">
                                                <i class="bi bi-check-lg"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => CancelOrder(o.Id)" title="Cancelar">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        }
                                        else if (o.Status == "Confirmado")
                                        {
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => CancelOrder(o.Id)" title="Cancelar">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">Nenhum pedido encontrado.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@code {
    private List<OrderDto>? orders;
    private bool loading = true;
    private string? errorMessage;
    private static readonly System.Globalization.CultureInfo ptBR = new("pt-BR");

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Api.EnsureInitializedAsync();
            await LoadOrders();
            StateHasChanged();
        }
    }

    private async Task LoadOrders()
    {
        loading = true;
        try
        {
            orders = await Api.GetAsync<List<OrderDto>>("api/orders") ?? [];
        }
        catch
        {
            errorMessage = "Erro ao carregar pedidos.";
        }
        finally
        {
            loading = false;
        }
    }

    private async Task ConfirmOrder(string id)
    {
        try
        {
            var (data, error) = await Api.PostWithErrorAsync<object, object>($"api/orders/{id}/confirm", new { });
            if (data is not null)
            {
                errorMessage = null;
                await LoadOrders();
            }
            else
            {
                errorMessage = error ?? "Erro ao confirmar pedido.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro ao confirmar pedido: {ex.Message}";
        }
        StateHasChanged();
    }

    private async Task CancelOrder(string id)
    {
        try
        {
            var (data, error) = await Api.PostWithErrorAsync<object, object>($"api/orders/{id}/cancel", new { Reason = "Cancelado pelo usuario" });
            if (data is not null)
            {
                errorMessage = null;
                await LoadOrders();
            }
            else
            {
                errorMessage = error ?? "Erro ao cancelar pedido.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro ao cancelar pedido: {ex.Message}";
        }
        StateHasChanged();
    }

    private string GetStatusBadge(string status) => status switch
    {
        "Rascunho" => "bg-secondary",
        "Confirmado" => "bg-primary",
        "Faturado" => "bg-success",
        "Cancelado" => "bg-danger",
        "Devolvido" => "bg-warning text-dark",
        _ => "bg-secondary"
    };

    public class OrderDto
    {
        public string Id { get; set; } = "";
        public string OrderNumber { get; set; } = "";
        public string CustomerName { get; set; } = "";
        public string Status { get; set; } = "";
        public decimal Total { get; set; }
        public DateTime CreatedAt { get; set; }
    }
}
