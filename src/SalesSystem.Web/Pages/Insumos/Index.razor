@page "/insumos"
@rendermode InteractiveServer
@inject ApiService Api
@inject NavigationManager Nav

<PageTitle>Insumos - SalesSystem</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="mb-0">Insumos</h3>
    <a href="/insumos/new" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Novo Insumo
    </a>
</div>

<AlertModal Visible="errorMessage is not null" Message="@(errorMessage ?? "")" Title="Erro" Type="error" OnClose="() => errorMessage = null" />

@if (loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Codigo</th>
                            <th>Nome</th>
                            <th class="text-end">Estoque</th>
                            <th class="text-end">Custo Medio</th>
                            <th class="text-center">Tipo</th>
                            <th>Status</th>
                            <th class="text-center">Acoes</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (insumos?.Any() == true)
                        {
                            @foreach (var i in insumos)
                            {
                                <tr>
                                    <td><code>@i.Code</code></td>
                                    <td>@i.Name</td>
                                    <td class="text-end">
                                        @FormatStock(i)
                                        @if (i.CurrentStock <= i.MinStock && i.CurrentStock > 0)
                                        {
                                            <i class="bi bi-exclamation-triangle text-warning ms-1" title="Estoque baixo"></i>
                                        }
                                        else if (i.CurrentStock == 0)
                                        {
                                            <i class="bi bi-x-circle text-danger ms-1" title="Sem estoque"></i>
                                        }
                                    </td>
                                    <td class="text-end">@FormatCost(i)</td>
                                    <td class="text-center">
                                        @if (i.IsSellable)
                                        {
                                            <span class="badge bg-success" title="Disponivel para venda">
                                                <i class="bi bi-bag-check me-1"></i>Venda
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge @(i.IsActive ? "bg-success" : "bg-secondary")">
                                            @(i.IsActive ? "Ativo" : "Inativo")
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <a href="/insumos/@i.Id/purchases" class="btn btn-sm btn-outline-success me-1" title="Compras">
                                            <i class="bi bi-cart-plus"></i>
                                        </a>
                                        <a href="/insumos/@i.Id/edit" class="btn btn-sm btn-outline-primary me-1" title="Editar">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteInsumo(i.Id)" title="Excluir">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="7" class="text-center text-muted py-4">Nenhum insumo cadastrado.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@code {
    private List<InsumoDto>? insumos;
    private bool loading = true;
    private string? errorMessage;
    private static readonly System.Globalization.CultureInfo ptBR = new("pt-BR");

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Api.EnsureInitializedAsync();
            await LoadInsumos();
            StateHasChanged();
        }
    }

    private async Task LoadInsumos()
    {
        loading = true;
        try { insumos = await Api.GetAsync<List<InsumoDto>>("api/insumos") ?? []; }
        catch { errorMessage = "Erro ao carregar insumos."; }
        finally { loading = false; }
    }

    private async Task DeleteInsumo(string id)
    {
        if (await Api.DeleteAsync($"api/insumos/{id}"))
            await LoadInsumos();
    }

    /// <summary>Exibe estoque na unidade do usuario. Ex: 5000g = "5 KG" ou "5000 g"</summary>
    private string FormatStock(InsumoDto i)
    {
        var factor = i.Unit switch { "KG" => 1000, "LT" => 1000, _ => 1 };
        if (factor > 1 && i.CurrentStock >= factor)
            return $"{(decimal)i.CurrentStock / factor:N2} {i.Unit}";
        return $"{i.CurrentStock:N0} {i.BaseUnit}";
    }

    /// <summary>Custo na unidade do usuario. Ex: custo/g * 1000 = custo/KG</summary>
    private string FormatCost(InsumoDto i)
    {
        var factor = i.Unit switch { "KG" => 1000, "LT" => 1000, _ => 1 };
        var costPerUnit = i.AverageCost * factor;
        return $"{costPerUnit.ToString("C", ptBR)}/{i.Unit}";
    }

    public class InsumoDto
    {
        public string Id { get; set; } = "";
        public string Code { get; set; } = "";
        public string Name { get; set; } = "";
        public string Unit { get; set; } = "KG";
        public string BaseUnit { get; set; } = "g";
        public long CurrentStock { get; set; }
        public long MinStock { get; set; }
        public decimal AverageCost { get; set; }
        public bool IsSellable { get; set; }
        public decimal SalePrice { get; set; }
        public string? ProductId { get; set; }
        public bool IsActive { get; set; }
    }
}
