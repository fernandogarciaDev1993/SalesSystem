@page "/products"
@rendermode InteractiveServer
@inject ApiService Api
@inject NavigationManager Nav

<PageTitle>Produtos - SalesSystem</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="mb-0">Produtos</h3>
    <a href="/products/new" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Novo Produto
    </a>
</div>

<AlertModal Visible="errorMessage is not null" Message="@(errorMessage ?? "")" Title="Erro" Type="error" OnClose="() => errorMessage = null" />

@if (loading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary"></div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Nome</th>
                            <th>SKU</th>
                            <th class="text-end">Preco Venda</th>
                            <th class="text-end">Preco Custo</th>
                            <th>Status</th>
                            <th class="text-center">Acoes</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (products?.Any() == true)
                        {
                            @foreach (var p in products)
                            {
                                <tr>
                                    <td>@p.Name</td>
                                    <td><code>@p.Sku</code></td>
                                    <td class="text-end">@p.SalePrice.ToString("C", ptBR)</td>
                                    <td class="text-end">@p.CostPrice.ToString("C", ptBR)</td>
                                    <td>
                                        <span class="badge @(p.IsActive ? "bg-success" : "bg-secondary")">
                                            @(p.IsActive ? "Ativo" : "Inativo")
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <a href="/products/@p.Id/edit" class="btn btn-sm btn-outline-primary me-1">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteProduct(p.Id)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">Nenhum produto cadastrado.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@code {
    private List<ProductDto>? products;
    private bool loading = true;
    private string? errorMessage;
    private static readonly System.Globalization.CultureInfo ptBR = new("pt-BR");

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Api.EnsureInitializedAsync();
            await LoadProducts();
            StateHasChanged();
        }
    }

    private async Task LoadProducts()
    {
        loading = true;
        try
        {
            products = await Api.GetAsync<List<ProductDto>>("api/products") ?? [];
        }
        catch
        {
            errorMessage = "Erro ao carregar produtos.";
        }
        finally
        {
            loading = false;
        }
    }

    private async Task DeleteProduct(string id)
    {
        var success = await Api.DeleteAsync($"api/products/{id}");
        if (success)
            await LoadProducts();
    }

    public class ProductDto
    {
        public string Id { get; set; } = "";
        public string Name { get; set; } = "";
        public string Sku { get; set; } = "";
        public decimal SalePrice { get; set; }
        public decimal CostPrice { get; set; }
        public bool IsActive { get; set; }
        public string? Description { get; set; }
        public decimal MinSalePrice { get; set; }
        public string Unit { get; set; } = "UN";
    }
}
