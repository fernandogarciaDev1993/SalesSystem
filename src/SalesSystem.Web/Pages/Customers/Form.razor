@page "/customers/new"
@page "/customers/{Id}/edit"
@rendermode InteractiveServer
@inject ApiService Api
@inject NavigationManager Nav

<PageTitle>@(IsEdit ? "Editar" : "Novo") Cliente - SalesSystem</PageTitle>

<div class="d-flex align-items-center mb-4">
    <a href="/customers" class="btn btn-sm btn-outline-secondary me-3">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h3 class="mb-0">@(IsEdit ? "Editar" : "Novo") Cliente</h3>
</div>

<AlertModal Visible="errorMessage is not null" Message="@(errorMessage ?? "")" Title="Erro" Type="error" OnClose="() => errorMessage = null" />

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <EditForm Model="model" OnValidSubmit="HandleSubmit" FormName="customerForm">
            <div class="row">
                <div class="col-md-8 mb-3">
                    <label class="form-label">Nome *</label>
                    <InputText @bind-Value="model.Name" class="form-control" />
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label">Tipo</label>
                    <InputSelect @bind-Value="model.Type" class="form-select">
                        <option value="PF">Pessoa Fisica</option>
                        <option value="PJ">Pessoa Juridica</option>
                    </InputSelect>
                </div>
            </div>
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label class="form-label">Documento (CPF/CNPJ) *</label>
                    <InputText @bind-Value="model.Document" class="form-control" />
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label">Email</label>
                    <InputText @bind-Value="model.Email" class="form-control" type="email" />
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label">Telefone</label>
                    <InputText @bind-Value="model.Phone" class="form-control" />
                </div>
            </div>
            <div class="row">
                <div class="col-md-3 mb-3">
                    <label class="form-label">Celular</label>
                    <InputText @bind-Value="model.Mobile" class="form-control" />
                </div>
                <div class="col-md-3 mb-3">
                    <label class="form-label">Data de Nascimento</label>
                    <InputDate @bind-Value="model.BirthDate" class="form-control" />
                </div>
                <div class="col-md-3 mb-3">
                    <label class="form-label">Limite de Credito</label>
                    <InputNumber @bind-Value="model.CreditLimit" class="form-control" />
                </div>
                <div class="col-md-3 mb-3">
                    <label class="form-label">Prazo Pagamento (dias)</label>
                    <InputNumber @bind-Value="model.PaymentTermDays" class="form-control" />
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label">Observacoes</label>
                <InputTextArea @bind-Value="model.Notes" class="form-control" rows="2" />
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary" disabled="@saving">
                    @if (saving)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    @(IsEdit ? "Salvar" : "Cadastrar")
                </button>
                <a href="/customers" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </EditForm>
    </div>
</div>

@code {
    [Parameter] public string? Id { get; set; }
    private bool IsEdit => !string.IsNullOrEmpty(Id);
    private CustomerModel model = new();
    private bool saving;
    private string? errorMessage;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Api.EnsureInitializedAsync();
            await LoadData();
            StateHasChanged();
        }
    }

    private async Task LoadData()
    {
        if (IsEdit)
        {
            try
            {
                var customer = await Api.GetAsync<CustomerModel>($"api/customers/{Id}");
                if (customer is not null) model = customer;
                else errorMessage = "Cliente nao encontrado.";
            }
            catch
            {
                errorMessage = "Erro ao carregar cliente.";
            }
        }
    }

    private async Task HandleSubmit()
    {
        saving = true;
        errorMessage = null;

        try
        {
            if (IsEdit)
            {
                var result = await Api.PutAsync<CustomerModel, CustomerModel>($"api/customers/{Id}", model);
                if (result is not null) Nav.NavigateTo("/customers");
                else errorMessage = "Erro ao atualizar cliente.";
            }
            else
            {
                var result = await Api.PostAsync<CustomerModel, CustomerModel>("api/customers", model);
                if (result is not null) Nav.NavigateTo("/customers");
                else errorMessage = "Erro ao cadastrar cliente.";
            }
        }
        catch
        {
            errorMessage = "Erro ao salvar cliente.";
        }
        finally
        {
            saving = false;
        }
    }

    public class CustomerModel
    {
        public string Id { get; set; } = "";
        public string Name { get; set; } = "";
        public string Document { get; set; } = "";
        public string Type { get; set; } = "PF";
        public string? Email { get; set; }
        public string? Phone { get; set; }
        public string? Mobile { get; set; }
        public decimal CreditLimit { get; set; }
        public int PaymentTermDays { get; set; }
        public DateTime? BirthDate { get; set; }
        public string? Notes { get; set; }
        public bool IsActive { get; set; } = true;
    }
}
