@page "/admin/tenants/{Id}/users"
@rendermode InteractiveServer
@inject ApiService Api
@inject NavigationManager Nav

<PageTitle>Usuarios do Tenant - SalesSystem</PageTitle>

@if (!Api.IsGlobalAdmin)
{
    <div class="d-flex justify-content-center align-items-center" style="min-height: 60vh;">
        <div class="text-center">
            <i class="bi bi-shield-lock fs-1 text-danger"></i>
            <h4 class="mt-3">Acesso Negado</h4>
            <p class="text-muted">Voce nao tem permissao para acessar esta pagina.</p>
            <a href="/" class="btn btn-primary">Voltar ao Inicio</a>
        </div>
    </div>
}
else
{
    <div class="d-flex align-items-center mb-4">
        <a href="/admin/tenants" class="btn btn-sm btn-outline-secondary me-3">
            <i class="bi bi-arrow-left"></i>
        </a>
        <h3 class="mb-0">Usuarios do Tenant</h3>
    </div>

    <AlertModal Visible="errorMessage is not null" Message="@(errorMessage ?? "")" Title="Erro" Type="error" OnClose="() => errorMessage = null" />
    <AlertModal Visible="successMessage is not null" Message="@(successMessage ?? "")" Title="Sucesso" Type="success" OnClose="() => successMessage = null" />

    <AlertModal Visible="deleteConfirmUserId is not null"
                Message="Tem certeza que deseja excluir este usuario?"
                Title="Confirmar Exclusao"
                Type="warning"
                ConfirmText="Excluir"
                OnConfirm="ConfirmDelete"
                OnClose="() => deleteConfirmUserId = null" />

    <div class="row">
        <div class="col-lg-8">
            @if (loading)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary"></div>
                </div>
            }
            else
            {
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Nome</th>
                                        <th>Email</th>
                                        <th>Perfil</th>
                                        <th>Status</th>
                                        <th>Acoes</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (users?.Any() == true)
                                    {
                                        @foreach (var u in users)
                                        {
                                            <tr>
                                                <td>@u.Name</td>
                                                <td>@u.Email</td>
                                                <td><span class="badge bg-info">@u.Role</span></td>
                                                <td>
                                                    <span class="badge @(u.IsActive ? "bg-success" : "bg-secondary")">
                                                        @(u.IsActive ? "Ativo" : "Inativo")
                                                    </span>
                                                </td>
                                                <td>
                                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => deleteConfirmUserId = u.Id" title="Excluir">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr><td colspan="5" class="text-center text-muted py-4">Nenhum usuario encontrado.</td></tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-light">
                    <h6 class="mb-0">Novo Usuario</h6>
                </div>
                <div class="card-body">
                    <EditForm Model="newUser" OnValidSubmit="HandleCreateUser" FormName="newUserForm">
                        <div class="mb-3">
                            <label class="form-label">Nome *</label>
                            <InputText @bind-Value="newUser.Name" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Email *</label>
                            <InputText @bind-Value="newUser.Email" class="form-control" type="email" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Senha *</label>
                            <InputText @bind-Value="newUser.Password" class="form-control" type="password" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Perfil</label>
                            <InputSelect @bind-Value="newUser.Role" class="form-select">
                                <option value="Admin">Admin</option>
                                <option value="Gerente">Gerente</option>
                                <option value="Vendedor">Vendedor</option>
                                <option value="Estoquista">Estoquista</option>
                                <option value="Financeiro">Financeiro</option>
                                <option value="Viewer">Viewer</option>
                            </InputSelect>
                        </div>
                        <button type="submit" class="btn btn-primary w-100" disabled="@savingUser">
                            @if (savingUser)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                            }
                            Cadastrar Usuario
                        </button>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string Id { get; set; } = "";

    private List<TenantUserDto>? users;
    private bool loading = true;
    private bool savingUser;
    private string? errorMessage;
    private string? successMessage;
    private string? deleteConfirmUserId;
    private NewUserModel newUser = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Api.EnsureInitializedAsync();
            if (!Api.IsGlobalAdmin)
            {
                loading = false;
                StateHasChanged();
                return;
            }
            await LoadData();
            StateHasChanged();
        }
    }

    private async Task LoadData()
    {
        try
        {
            users = await Api.GetAsync<List<TenantUserDto>>($"api/admin/tenants/{Id}/users") ?? [];
        }
        catch { errorMessage = "Erro ao carregar usuarios."; }
        finally { loading = false; }
    }

    private async Task HandleCreateUser()
    {
        savingUser = true;
        errorMessage = null;
        successMessage = null;
        try
        {
            await Api.EnsureInitializedAsync();
            var response = await Api.PostRawAsync($"api/admin/tenants/{Id}/users", newUser);
            if (response.IsSuccess)
            {
                successMessage = "Usuario criado com sucesso.";
                newUser = new();
                loading = true;
                await LoadData();
            }
            else
            {
                errorMessage = response.Error ?? "Erro ao criar usuario.";
            }
        }
        catch (Exception ex) { errorMessage = $"Erro: {ex.Message}"; }
        finally { savingUser = false; }
    }

    private async Task ConfirmDelete()
    {
        if (deleteConfirmUserId is null) return;
        errorMessage = null;
        successMessage = null;
        try
        {
            var success = await Api.DeleteAsync($"api/admin/tenants/{Id}/users/{deleteConfirmUserId}");
            if (success)
            {
                successMessage = "Usuario excluido.";
                loading = true;
                StateHasChanged();
                await LoadData();
            }
            else errorMessage = "Erro ao excluir usuario.";
        }
        catch { errorMessage = "Erro ao excluir usuario."; }
        finally { deleteConfirmUserId = null; }
    }

    public class TenantUserDto
    {
        public string Id { get; set; } = "";
        public string Name { get; set; } = "";
        public string Email { get; set; } = "";
        public string Role { get; set; } = "";
        public bool IsActive { get; set; }
    }

    public class NewUserModel
    {
        public string Name { get; set; } = "";
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
        public string Role { get; set; } = "Vendedor";
    }
}
