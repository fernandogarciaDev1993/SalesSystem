@page "/admin/tenants"
@rendermode InteractiveServer
@inject ApiService Api
@inject NavigationManager Nav

<PageTitle>Tenants - SalesSystem</PageTitle>

@if (!Api.IsGlobalAdmin)
{
    <div class="d-flex justify-content-center align-items-center" style="min-height: 60vh;">
        <div class="text-center">
            <i class="bi bi-shield-lock fs-1 text-danger"></i>
            <h4 class="mt-3">Acesso Negado</h4>
            <p class="text-muted">Voce nao tem permissao para acessar esta pagina.</p>
            <a href="/" class="btn btn-primary">Voltar ao Inicio</a>
        </div>
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="mb-0">Tenants</h3>
        <a href="/admin/tenants/new" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>Novo Tenant
        </a>
    </div>

    <AlertModal Visible="errorMessage is not null" Message="@(errorMessage ?? "")" Title="Erro" Type="error" OnClose="() => errorMessage = null" />

    @if (loading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary"></div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Nome</th>
                                <th>Subdominio</th>
                                <th>Plano</th>
                                <th>Status</th>
                                <th>Acoes</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (tenants?.Any() == true)
                            {
                                @foreach (var t in tenants)
                                {
                                    <tr>
                                        <td>@t.Name</td>
                                        <td><code>@t.Subdomain</code></td>
                                        <td><span class="badge bg-info">@t.Plan</span></td>
                                        <td>
                                            <span class="badge @(t.IsActive ? "bg-success" : "bg-secondary")">
                                                @(t.IsActive ? "Ativo" : "Inativo")
                                            </span>
                                        </td>
                                        <td>
                                            <div class="btn-group btn-group-sm">
                                                <a href="/admin/tenants/@t.Id/edit" class="btn btn-outline-primary" title="Editar">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                                <a href="/admin/tenants/@t.Id/ui" class="btn btn-outline-secondary" title="Aparencia">
                                                    <i class="bi bi-palette"></i>
                                                </a>
                                                <a href="/admin/tenants/@t.Id/vocabulary" class="btn btn-outline-secondary" title="Vocabulário">
                                                    <i class="bi bi-translate"></i>
                                                </a>
                                                <a href="/admin/tenants/@t.Id/users" class="btn btn-outline-secondary" title="Usuarios">
                                                    <i class="bi bi-people"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="5" class="text-center text-muted py-4">Nenhum tenant encontrado.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
}

@code {
    private List<TenantDto>? tenants;
    private bool loading = true;
    private string? errorMessage;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Api.EnsureInitializedAsync();
            if (!Api.IsGlobalAdmin)
            {
                loading = false;
                StateHasChanged();
                return;
            }
            await LoadData();
            StateHasChanged();
        }
    }

    private async Task LoadData()
    {
        try
        {
            tenants = await Api.GetAsync<List<TenantDto>>("api/admin/tenants") ?? [];
        }
        catch
        {
            errorMessage = "Erro ao carregar tenants.";
        }
        finally { loading = false; }
    }

    public class TenantDto
    {
        public string Id { get; set; } = "";
        public string Name { get; set; } = "";
        public string Subdomain { get; set; } = "";
        public string Plan { get; set; } = "";
        public bool IsActive { get; set; }
    }
}
