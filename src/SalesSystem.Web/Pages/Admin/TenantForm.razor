@page "/admin/tenants/new"
@page "/admin/tenants/{Id}/edit"
@rendermode InteractiveServer
@inject ApiService Api
@inject NavigationManager Nav

<PageTitle>@(IsEdit ? "Editar" : "Novo") Tenant - SalesSystem</PageTitle>

@if (!Api.IsGlobalAdmin)
{
    <div class="d-flex justify-content-center align-items-center" style="min-height: 60vh;">
        <div class="text-center">
            <i class="bi bi-shield-lock fs-1 text-danger"></i>
            <h4 class="mt-3">Acesso Negado</h4>
            <p class="text-muted">Voce nao tem permissao para acessar esta pagina.</p>
            <a href="/" class="btn btn-primary">Voltar ao Inicio</a>
        </div>
    </div>
}
else
{
    <div class="d-flex align-items-center mb-4">
        <a href="/admin/tenants" class="btn btn-sm btn-outline-secondary me-3">
            <i class="bi bi-arrow-left"></i>
        </a>
        <h3 class="mb-0">@(IsEdit ? "Editar" : "Novo") Tenant</h3>
    </div>

    <AlertModal Visible="errorMessage is not null" Message="@(errorMessage ?? "")" Title="Erro" Type="error" OnClose="() => errorMessage = null" />

    @if (loadingData)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary"></div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <EditForm Model="model" OnValidSubmit="HandleSubmit" FormName="tenantForm">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Nome *</label>
                            <InputText @bind-Value="model.Name" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Subdominio *</label>
                            <InputText @bind-Value="model.Subdomain" class="form-control" placeholder="meu-tenant" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Documento</label>
                            <InputText @bind-Value="model.Document" class="form-control" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Email</label>
                            <InputText @bind-Value="model.Email" class="form-control" type="email" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Telefone</label>
                            <InputText @bind-Value="model.Phone" class="form-control" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Plano</label>
                            <InputSelect @bind-Value="model.Plan" class="form-select">
                                <option value="free">Free</option>
                                <option value="standard">Standard</option>
                                <option value="premium">Premium</option>
                            </InputSelect>
                        </div>
                        <div class="col-md-4 mb-3 d-flex align-items-end">
                            <div class="form-check">
                                <InputCheckbox @bind-Value="model.IsActive" class="form-check-input" id="isActive" />
                                <label class="form-check-label" for="isActive">Ativo</label>
                            </div>
                        </div>
                    </div>

                    <h5 class="mt-3 mb-3">Modulos</h5>
                    <div class="row">
                        @foreach (var mod in availableModules)
                        {
                            <div class="col-md-3 mb-2">
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" id="mod-@mod"
                                           checked="@model.Modules.Contains(mod)"
                                           @onchange="e => ToggleModule(mod, (bool)(e.Value ?? false))" />
                                    <label class="form-check-label" for="mod-@mod">@mod</label>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary" disabled="@saving">
                            @if (saving)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                            }
                            @(IsEdit ? "Salvar" : "Cadastrar")
                        </button>
                        <a href="/admin/tenants" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </EditForm>
            </div>
        </div>
    }
}

@code {
    [Parameter] public string? Id { get; set; }

    private bool IsEdit => !string.IsNullOrEmpty(Id);
    private TenantModel model = new();
    private bool saving;
    private bool loadingData;
    private string? errorMessage;

    private readonly string[] availableModules = ["produtos", "clientes", "estoque", "pedidos", "financeiro", "insumos", "receitas"];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Api.EnsureInitializedAsync();
            if (!Api.IsGlobalAdmin)
            {
                StateHasChanged();
                return;
            }

            if (IsEdit)
            {
                loadingData = true;
                StateHasChanged();
                try
                {
                    var tenant = await Api.GetAsync<TenantModel>($"api/admin/tenants/{Id}");
                    if (tenant is not null) model = tenant;
                    else errorMessage = "Tenant nao encontrado.";
                }
                catch { errorMessage = "Erro ao carregar tenant."; }
                finally { loadingData = false; }
            }

            StateHasChanged();
        }
    }

    private void ToggleModule(string module, bool isChecked)
    {
        if (isChecked && !model.Modules.Contains(module))
            model.Modules.Add(module);
        else if (!isChecked)
            model.Modules.Remove(module);
    }

    private async Task HandleSubmit()
    {
        saving = true;
        errorMessage = null;
        try
        {
            bool success;
            if (IsEdit)
                success = await Api.PutAsync($"api/admin/tenants/{Id}", model);
            else
            {
                var result = await Api.PostAsync<TenantModel, object>("api/admin/tenants", model);
                success = result is not null;
            }

            if (success) Nav.NavigateTo("/admin/tenants");
            else errorMessage = "Erro ao salvar tenant.";
        }
        catch { errorMessage = "Erro ao salvar tenant."; }
        finally { saving = false; }
    }

    public class TenantModel
    {
        public string Name { get; set; } = "";
        public string Subdomain { get; set; } = "";
        public string Document { get; set; } = "";
        public string Email { get; set; } = "";
        public string Phone { get; set; } = "";
        public string Plan { get; set; } = "free";
        public bool IsActive { get; set; } = true;
        public List<string> Modules { get; set; } = [];
    }
}
