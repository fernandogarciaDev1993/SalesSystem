@page "/users/new"
@rendermode InteractiveServer
@inject ApiService Api
@inject NavigationManager Nav

<PageTitle>Novo Usuario - SalesSystem</PageTitle>

<div class="d-flex align-items-center mb-4">
    <a href="/users" class="btn btn-sm btn-outline-secondary me-3">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h3 class="mb-0">Novo Usuario</h3>
</div>

<AlertModal Visible="errorMessage is not null" Message="@(errorMessage ?? "")" Title="Erro" Type="error" OnClose="() => errorMessage = null" />

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <EditForm Model="model" OnValidSubmit="HandleSubmit" FormName="userForm">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Nome *</label>
                    <InputText @bind-Value="model.Name" class="form-control" />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Email *</label>
                    <InputText @bind-Value="model.Email" class="form-control" type="email" />
                </div>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Senha *</label>
                    <InputText @bind-Value="model.Password" class="form-control" type="password" />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Perfil</label>
                    <InputSelect @bind-Value="model.Role" class="form-select">
                        <option value="Admin">Admin</option>
                        <option value="Gerente">Gerente</option>
                        <option value="Vendedor">Vendedor</option>
                        <option value="Estoquista">Estoquista</option>
                        <option value="Financeiro">Financeiro</option>
                        <option value="Viewer">Viewer</option>
                    </InputSelect>
                </div>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary" disabled="@saving">
                    @if (saving)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    Cadastrar
                </button>
                <a href="/users" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </EditForm>
    </div>
</div>

@code {
    private UserModel model = new();
    private bool saving;
    private string? errorMessage;

    private async Task HandleSubmit()
    {
        saving = true;
        errorMessage = null;
        try
        {
            var result = await Api.PostAsync<UserModel, object>("api/users", model);
            if (result is not null) Nav.NavigateTo("/users");
            else errorMessage = "Erro ao cadastrar usuario.";
        }
        catch { errorMessage = "Erro ao cadastrar usuario."; }
        finally { saving = false; }
    }

    public class UserModel
    {
        public string Name { get; set; } = "";
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
        public string Role { get; set; } = "Vendedor";
    }
}
